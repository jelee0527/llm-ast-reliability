# API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Experiment settings
EXPERIMENT_REPEATS=5

# Provider-specific temperature, maximum output length, and reasoning
# settings are defined in configs/models.yaml. Uncomment these only when
# intentionally applying one global override to the selected model run.
# EXPERIMENT_TEMPERATURE=0.2
# EXPERIMENT_MAX_TOKENS=1200

# Optional filters
# 0 means all problems
EXPERIMENT_MAX_PROBLEMS=0
EXPERIMENT_MODEL_FILTER=
EXPERIMENT_PROMPT_FILTER=